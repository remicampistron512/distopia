@startuml
actor Utilisateur
participant "AuthController" as AuthController
participant "AuthService" as AuthService
participant "UserRepository" as UserRepository
database "Base de données" as DB
participant "HttpSession" as Session

Utilisateur -> AuthController : GET /login
AuthController --> Utilisateur : retourne la vue "login"

Utilisateur -> AuthController : POST /login(username, password)
AuthController -> AuthService : authenticate(username, password)

AuthService -> UserRepository : findByUsername(username)
UserRepository -> DB : recherche utilisateur
DB --> UserRepository : User / vide
UserRepository --> AuthService : Optional<User>

alt utilisateur introuvable
    AuthService --> AuthController : UserNotFoundException
    AuthController -> AuthController : addFlashAttribute("errorMessage")
    AuthController --> Utilisateur : redirect:/login
else utilisateur trouvé
    AuthService -> AuthService : compare password avec user.password

    alt mot de passe incorrect
        AuthService --> AuthController : BadCredentialsException
        AuthController -> AuthController : addFlashAttribute("errorMessage")
        AuthController --> Utilisateur : redirect:/login
    else mot de passe correct
        AuthService --> AuthController : User
        AuthController -> AuthController : création SessionUser(id, username, role)
        AuthController -> Session : setAttribute("loggedUser", sessionUser)
        AuthController -> AuthController : addFlashAttribute("successMessage")
        AuthController --> Utilisateur : redirect:/
    end
end
@enduml